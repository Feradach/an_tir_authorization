# Copy to .env and fill in values on the server

# Core Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
DJANGO_ALLOWED_HOSTS=[WEBSITE],[IP ADDRESS],localhost
SITE_URL=https://authorizations.thebusinessduck.com
CSRF_TRUSTED_ORIGINS=https://authorizations.thebusinessduck.com

# Database (MySQL)
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=3306

# Email
# For temporary Gmail SMTP sending, use:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=temporary-sender@gmail.com
# EMAIL_HOST_PASSWORD=16-character-google-app-password
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=Antir Database <temporary-sender@gmail.com>
EMAIL_BACKEND=authorizations.email_backends.GmailAPIBackend
DEFAULT_FROM_EMAIL=Antir Database <antir.authorization.database@gmail.com>

# Gmail API credentials, used when EMAIL_BACKEND=authorizations.email_backends.GmailAPIBackend
GMAIL_TOKEN_FILE=[FILEPATH]/token.json

# MS Email Credentials
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MS_TOKEN_FILE=

# Site Testing Settings
AUTHZ_TEST_FEATURES = 1 or 0
