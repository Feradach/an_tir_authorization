# Copy to /home/feradach/an_tir_authorization/.env on PythonAnywhere and fill in the placeholder values.

# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=feradach.pythonanywhere.com
CSRF_TRUSTED_ORIGINS=https://feradach.pythonanywhere.com
SITE_URL=https://feradach.pythonanywhere.com
USE_X_FORWARDED_HOST=True
DJANGO_ADMIN_EMAILS=Don Reynolds <don.k.a.reynolds@outlook.com>
RELEASE_ENV=production

# Database
DB_ENGINE=django.db.backends.mysql
DB_NAME=feradach$your_database_name
DB_USER=feradach
DB_PASSWORD=replace-with-database-password
DB_HOST=replace-with-website-host
DB_PORT=3306

# Email
# EMAIL_DELIVERY_MODE must be one of: file, gmail, smtp
EMAIL_DELIVERY_MODE=gmail

# File settings
EMAIL_FILE_PATH=

# Gmail settings
DEFAULT_FROM_EMAIL=Antir Database <antir.authorization.database@gmail.com>
SERVER_EMAIL=Antir Database <antir.authorization.database@gmail.com>
GMAIL_TOKEN_FILE=etc/gmail-prod-token.json

# SMTP settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_TIMEOUT=30

# Feature flags
AUTHZ_TEST_FEATURES=0
AUTHZ_REQUIRE_FIGHTER_CONCURRENCE=0

# Cache
DJANGO_CACHE_BACKEND=django.core.cache.backends.db.DatabaseCache
DJANGO_CACHE_LOCATION=django_cache

# Files and logs
MEDIA_ROOT=/srv/an_tir/media
SECURITY_EVENTS_LOG_PATH=/var/log/an_tir_authorizations/security_events.log
USE_WHITENOISE=True

# HTTPS
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SECURE=True
SECURE_CONTENT_TYPE_NOSNIFF=True
SECURE_BROWSER_XSS_FILTER=True
