# Copy to .env and fill in values on the server

# Core Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
DJANGO_ALLOWED_HOSTS=[WEBSITE],[IP ADDRESS],localhost

# Database (MySQL)
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=3306

# GMail Email Credentials
GMAIL_CLIENT_SECRET=[FILEPATH]/client_secret.json
GMAIL_TOKEN_FILE=[FILEPATH]/token.json
DEFAULT_FROM_EMAIL=Sending_email

# MS Email Credentials
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MS_TOKEN_FILE=
DEFAULT_FROM_EMAIL=.

# Site Testing Settings
AUTHZ_TEST_FEATURES = 1 or 0
